<Window x:Class="HardwareMonitor.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hardware Monitor Overlay"
        Width="280" Height="200"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Left="100" Top="100">

    <Border Background="#E60F172A" CornerRadius="12" Padding="16"
            BorderBrush="#334155" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" Opacity="0.3" ShadowDepth="2"/>
        </Border.Effect>

        <StackPanel>
            <Grid Margin="0,0,0,8">
                <TextBlock Text="硬件监控" FontSize="12" Foreground="#64748B"
                           HorizontalAlignment="Left"/>
                <TextBlock Text="✕" FontSize="14" Foreground="#64748B"
                           HorizontalAlignment="Right" Cursor="Hand"
                           MouseLeftButtonDown="CloseClick"/>
            </Grid>

            <WrapPanel>
                <!-- CPU -->
                <StackPanel Width="80" Margin="0,0,8,8">
                    <TextBlock Text="CPU" FontSize="10" Foreground="#64748B"/>
                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#60A5FA">
                        <TextBlock.Text>
                            <Binding Path="Cpu.TotalLoad" StringFormat="{}{0:F0}%"/>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="#F59E0B">
                        <TextBlock.Text>
                            <Binding Path="Cpu.Temperature" StringFormat="{}{0:F0}°C"/>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>

                <!-- GPU -->
                <StackPanel Width="80" Margin="0,0,8,8">
                    <TextBlock Text="GPU" FontSize="10" Foreground="#64748B"/>
                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#60A5FA">
                        <TextBlock.Text>
                            <Binding Path="Gpu.CoreLoad" StringFormat="{}{0:F0}%"/>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="#F59E0B">
                        <TextBlock.Text>
                            <Binding Path="Gpu.Temperature" StringFormat="{}{0:F0}°C"/>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>

                <!-- RAM -->
                <StackPanel Width="80" Margin="0,0,8,8">
                    <TextBlock Text="RAM" FontSize="10" Foreground="#64748B"/>
                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#60A5FA">
                        <TextBlock.Text>
                            <Binding Path="Memory.UsagePercent" StringFormat="{}{0:F0}%"/>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </WrapPanel>

            <!-- Network -->
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <TextBlock Text="↑" Foreground="#22C55E" FontSize="11" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding Network.UploadSpeed, StringFormat={}{0:F0} B/s}"
                           Foreground="#94A3B8" FontSize="11" Margin="0,0,12,0"/>
                <TextBlock Text="↓" Foreground="#3B82F6" FontSize="11" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding Network.DownloadSpeed, StringFormat={}{0:F0} B/s}"
                           Foreground="#94A3B8" FontSize="11"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
