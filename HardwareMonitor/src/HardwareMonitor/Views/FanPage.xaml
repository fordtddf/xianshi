<UserControl x:Class="HardwareMonitor.Views.FanPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:HardwareMonitor.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="700">

    <UserControl.Resources>
        <Style x:Key="ModeButton" TargetType="RadioButton">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="#334155"
                                BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center">
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#334155"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel>
            <TextBlock Text="风扇控制" FontSize="20" FontWeight="Bold" Foreground="#E2E8F0" Margin="0,0,0,20"/>

            <!-- Mode Selection -->
            <TextBlock Text="选择模式" Foreground="#94A3B8" Margin="0,0,0,12"/>
            <ItemsControl ItemsSource="{Binding ModeOptions}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:FanModeOption}">
                        <RadioButton Style="{StaticResource ModeButton}"
                                     IsChecked="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                     Command="{Binding DataContext.SetModeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                     CommandParameter="{Binding Mode}">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.7" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Fan Curve Editor -->
            <Border Background="#1E293B" CornerRadius="12" Padding="20" Margin="0,20,0,0">
                <StackPanel>
                    <TextBlock Text="风扇曲线" FontSize="16" FontWeight="SemiBold" Foreground="#E2E8F0" Margin="0,0,0,16"/>

                    <!-- Curve Visualization -->
                    <Border Background="#0F172A" CornerRadius="8" Height="200" Margin="0,0,0,16">
                        <Canvas x:Name="CurveCanvas" ClipToBounds="True"/>
                    </Border>

                    <!-- Curve Points -->
                    <DataGrid ItemsSource="{Binding CustomCurvePoints}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              Background="#0F172A"
                              Foreground="#E2E8F0"
                              GridLinesVisibility="None"
                              BorderBrush="#334155"
                              BorderThickness="1"
                              RowBackground="#1E293B"
                              AlternatingRowBackground="#0F172A">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="温度 (°C)" Binding="{Binding Temperature, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                            <DataGridTextColumn Header="风扇转速 (%)" Binding="{Binding FanSpeedPercent, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Curve Actions -->
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="添加节点" Command="{Binding AddCurvePointCommand}"
                                Background="#1D4ED8" Foreground="White" Padding="12,6"
                                BorderThickness="0" Margin="0,0,8,0"/>
                        <Button Content="删除选中" Command="{Binding RemoveCurvePointCommand}"
                                Background="#DC2626" Foreground="White" Padding="12,6"
                                BorderThickness="0" Margin="0,0,8,0"/>
                        <Button Content="应用" Command="{Binding ApplyCustomCurveCommand}"
                                Background="#059669" Foreground="White" Padding="12,6"
                                BorderThickness="0" Margin="0,0,8,0"/>
                        <Button Content="静音预设" Command="{Binding ResetToPresetCommand}" CommandParameter="Silent"
                                Background="#334155" Foreground="#94A3B8" Padding="12,6"
                                BorderThickness="0" Margin="0,0,8,0"/>
                        <Button Content="平衡预设" Command="{Binding ResetToPresetCommand}" CommandParameter="Balance"
                                Background="#334155" Foreground="#94A3B8" Padding="12,6"
                                BorderThickness="0" Margin="0,0,8,0"/>
                        <Button Content="性能预设" Command="{Binding ResetToPresetCommand}" CommandParameter="Performance"
                                Background="#334155" Foreground="#94A3B8" Padding="12,6"
                                BorderThickness="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Info -->
            <Border Background="#1E293B" CornerRadius="12" Padding="16" Margin="0,16,0,0">
                <TextBlock TextWrapping="Wrap" Foreground="#94A3B8" FontSize="12">
                    注意：自动模式下风扇由 BIOS 控制。手动模式通过 ACPI/EC 接口控制风扇转速，
                    不同主板的兼容性可能不同。如果手动控制不生效，请检查主板是否支持 EC 风扇控制。
                    温度过高时会自动恢复 BIOS 默认策略以保护硬件。
                </TextBlock>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
