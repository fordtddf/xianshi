<UserControl x:Class="HardwareMonitor.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="700">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel MaxWidth="500">
            <TextBlock Text="设置" FontSize="20" FontWeight="Bold" Foreground="#E2E8F0" Margin="0,0,0,24"/>

            <!-- General Settings -->
            <TextBlock Text="常规" Foreground="#64748B" FontSize="12" Margin="0,0,0,12"/>

            <Border Background="#1E293B" CornerRadius="12" Padding="16">
                <StackPanel>
                    <CheckBox Content="开机自启动" IsChecked="{Binding AutoStart}"
                              Foreground="#E2E8F0" Margin="0,0,0,12"/>
                    <CheckBox Content="最小化到托盘" IsChecked="{Binding MinimizeToTray}"
                              Foreground="#E2E8F0" Margin="0,0,0,12"/>
                    <CheckBox Content="显示温度报警" IsChecked="{Binding ShowTemperatureAlert}"
                              Foreground="#E2E8F0" Margin="0,0,0,12"/>
                    <CheckBox Content="显示悬浮窗" IsChecked="{Binding ShowOverlay}"
                              Foreground="#E2E8F0"/>
                </StackPanel>
            </Border>

            <!-- Temperature Alert -->
            <TextBlock Text="温度报警" Foreground="#64748B" FontSize="12" Margin="0,20,0,12"/>

            <Border Background="#1E293B" CornerRadius="12" Padding="16">
                <StackPanel>
                    <TextBlock Text="报警阈值" Foreground="#94A3B8" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Slider Value="{Binding TemperatureAlertThreshold}"
                                Minimum="60" Maximum="105" Width="200"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TemperatureAlertThreshold, StringFormat={}{0:F0}°C}"
                                   Foreground="#E2E8F0" Margin="12,0,0,0"
                                   VerticalAlignment="Center" FontSize="16"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Refresh Interval -->
            <TextBlock Text="刷新间隔" Foreground="#64748B" FontSize="12" Margin="0,20,0,12"/>

            <Border Background="#1E293B" CornerRadius="12" Padding="16">
                <StackPanel>
                    <TextBlock Text="数据刷新间隔" Foreground="#94A3B8" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Slider Value="{Binding RefreshInterval}"
                                Minimum="1" Maximum="10" TickFrequency="1"
                                IsSnapToTickEnabled="True" Width="200"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding RefreshInterval, StringFormat={}{0}秒}"
                                   Foreground="#E2E8F0" Margin="12,0,0,0"
                                   VerticalAlignment="Center" FontSize="16"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Tray Display Mode -->
            <TextBlock Text="托盘显示" Foreground="#64748B" FontSize="12" Margin="0,20,0,12"/>

            <Border Background="#1E293B" CornerRadius="12" Padding="16">
                <StackPanel>
                    <TextBlock Text="托盘图标显示内容" Foreground="#94A3B8" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding TrayDisplayModes}"
                              SelectedItem="{Binding TrayDisplayMode}"
                              Width="200" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Display Items -->
            <TextBlock Text="显示项目" Foreground="#64748B" FontSize="12" Margin="0,20,0,12"/>

            <Border Background="#1E293B" CornerRadius="12" Padding="16">
                <ItemsControl ItemsSource="{Binding DisplayItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,4" Margin="0,2">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding IsVisible, UpdateSourceTrigger=PropertyChanged}"
                                              Foreground="#E2E8F0"/>
                                    <TextBlock Text="{Binding Type}" Foreground="#E2E8F0"
                                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- Save Button -->
            <Button Content="保存设置" Command="{Binding SaveCommand}"
                    Background="#1D4ED8" Foreground="White" Padding="24,10"
                    BorderThickness="0" Margin="0,24,0,0"
                    HorizontalAlignment="Left"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
